{
  "name": "frontend",
  "version": "3.1.2",
  "engines": {
    "node": ">=26.0.0"
  },
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--no-deprecation' next dev -p 3500",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "E2E_RUN=1 playwright test",
    "test:e2e:unified": "E2E_UNIFIED=1 playwright test e2e/unified-auth.spec.ts",
    "test:e2e:local": "bash scripts/e2e-local.sh",
    "test:e2e:ui": "E2E_RUN=1 playwright test --ui"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",

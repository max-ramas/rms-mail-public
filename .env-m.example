# =============================================================================
# RMS Mail — Mono Edition
# =============================================================================
# Copy to .env and set your values.
# Generate encryption key: openssl rand -hex 32
# =============================================================================

# Compose reads `.env` for substitution; production compose files use `env_file`
# plus explicit `environment` entries on the backend service.

# --- Encryption (REQUIRED) ---
# Primary + fallback keys for key rotation. First key encrypts new data,
# all keys tried for decryption. Separate multiple keys with commas.
# FATAL: application will not start without this
ENCRYPTION_KEYS=
# Single-key fallback (use EITHER ENCRYPTION_KEYS or ENCRYPTION_KEY)
# ENCRYPTION_KEY=

# --- JWT Signing (REQUIRED) ---
# Key for signing JWT auth tokens. Must be a random string (min 32 chars).
# Generate: openssl rand -hex 32
# FATAL: application will not start without this
JWT_SECRET=

# --- Camo Proxy (optional for Mono) ---
# Unified/Teams: REQUIRED in production — HMAC for proxied avatar/image URLs.
# Mono: optional — if unset, derived automatically from ENCRYPTION_KEYS.
# Generate: openssl rand -hex 32
# CAMO_HMAC_KEY=

# --- Server ---
PORT=8080
UI_PORT=3000
# Public URL of the web UI (scheme + host, no trailing slash).
# Production (HTTPS behind aaPanel/nginx): https://mail.yourdomain.com
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
# Optional: force MCP connect JSON / SSE endpoint URLs (defaults to FRONTEND_URL)
# MCP_API_URL=https://mail.yourdomain.com

# --- aaPanel / reverse proxy (Mono) ---
# Point the site proxy to UI_PORT (3000) only. Do NOT expose backend :8080 publicly.
# Required proxy headers toward Next.js (prevents http:// links / mixed content):
#   proxy_set_header Host $host;
#   proxy_set_header X-Forwarded-Host $host;
#   proxy_set_header X-Forwarded-Proto $scheme;
#   proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
# Set FRONTEND_URL and ALLOWED_ORIGINS to your https:// public origin.
# Next.js rewrites /api/* and /mcp/* to the backend on the Docker network.

# --- AI: Enterprise Lockdown ---
# Set to "true" to force all AI ops to use LLM_PROVIDER/LLM_MODEL,
# ignoring user-configured values in the web UI.
# LLM_ENVONLY=false
# LLM_PROVIDER=openrouter
# LLM_MODEL=

# --- AI: Provider API Keys (optional, can be set in web UI instead) ---
# OpenRouter (default, 200+ models)
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=
# OpenAI
# OPENAI_API_KEY=
# OPENAI_MODEL=
# Anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=
# Google Gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=
# DeepSeek
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=
# Groq
# GROQ_API_KEY=
# GROQ_MODEL=
# xAI (Grok)
# XAI_API_KEY=
# XAI_MODEL=
# Ollama (self-hosted)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=
# Qwen
# QWEN_API_KEY=
# QWEN_MODEL=
# OpenCode (self-hosted)
# OPENCODE_URL=
# OPENCODE_MODEL=
# Default provider if none configured in UI
# DEFAULT_AI_PROVIDER=openrouter

# --- Telegram Bot ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_NAME=
# Lock Telegram settings to env-only (ignores UI-configured token)
# TG_ENVONLY=false

# --- Mail Server Auto-Discovery ---
# Optional: trusted domains for auto-resolving IMAP/SMTP via hosting panel APIs.
# TRUSTED_MX_DOMAINS=
# RMS_MAIL_HOST=mail.example.com
# RMS_IMAP_HOST=imap.example.com
# RMS_SMTP_HOST=smtp.example.com

# --- IMAP sync (optional) ---
# Max concurrent IMAP dials per host (burst limit during connect/reconnect).
# Default 10, max 128. Open IDLE/sync sessions do not consume slots.
# IMAP_PER_HOST_CONN=12
# SYNC_MAX_WORKERS=50
# SYNC_BATCH_DELAY_MS=2000

# --- Debug ---
# DEBUG=false

# AI features toggle (true = all AI disabled, no chat/summarize/autodraft)
AI_DISABLE=false
# ALLOW_GLOBAL_AI_KEYS=true  # Allow fallback to global AI provider keys (default: false)

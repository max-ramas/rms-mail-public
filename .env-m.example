# =============================================================================
# RMS Mail — Mono Edition
# =============================================================================
# Copy to .env-m and set your values.
# Generate encryption key: openssl rand -hex 32
# =============================================================================

# --- Encryption (REQUIRED) ---
# Primary + fallback keys for key rotation. First key encrypts new data,
# all keys tried for decryption. Separate multiple keys with commas.
# ENCRYPTION_KEYS=
# Single-key fallback (use EITHER ENCRYPTION_KEYS or ENCRYPTION_KEY)
ENCRYPTION_KEY=

# --- Server ---
PORT=8080
UI_PORT=3000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# --- AI: Enterprise Lockdown ---
# Set to "true" to force all AI ops to use LLM_PROVIDER/LLM_MODEL,
# ignoring user-configured values in the web UI.
# LLM_ENVONLY=false
# LLM_PROVIDER=openrouter
# LLM_MODEL=

# AI functions disabling, set true to disable
AI_DISABLE=false

# --- AI: Provider API Keys (optional, can be set in web UI instead) ---
# OpenRouter (default, 200+ models)
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=
# OpenAI
# OPENAI_API_KEY=
# OPENAI_MODEL=
# Anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=
# Google Gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=
# DeepSeek
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=
# Groq
# GROQ_API_KEY=
# GROQ_MODEL=
# xAI (Grok)
# XAI_API_KEY=
# XAI_MODEL=
# Ollama (self-hosted)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=
# Qwen
# QWEN_API_KEY=
# QWEN_MODEL=
# OpenCode (self-hosted)
# OPENCODE_URL=
# OPENCODE_MODEL=
# Default provider if none configured in UI
# DEFAULT_AI_PROVIDER=openrouter

# --- Telegram Bot ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_NAME=
# Lock Telegram settings to env-only (ignores UI-configured token)
# TG_ENVONLY=false

# --- Mail Server Auto-Discovery ---
# Optional: trusted domains for auto-resolving IMAP/SMTP via hosting panel APIs.
# TRUSTED_MX_DOMAINS=

# --- Debug ---
# DEBUG=false

# =============================================================================
# RMS Mail — Mono Pro Edition
# =============================================================================
# Copy to .env and set your values.
# Generate encryption key: openssl rand -hex 32
# =============================================================================

# Compose reads `.env` for variable substitution and passes backend vars via
# `env_file` + the `environment` block in docker-compose-mp.yml.

# --- Database (REQUIRED) ---
# FATAL: application will not start without this
POSTGRES_USER=rmsmail
POSTGRES_DB=geomail_mp
# FATAL: compose will refuse to start if empty
POSTGRES_PASSWORD=
REDIS_PASSWORD=
# Optional: override host/port (default: postgres:5432)
# POSTGRES_HOST=postgres:5432
# Or set DATABASE_URL directly instead of individual vars:
# DATABASE_URL=postgres://user:pass@host:5432/db?sslmode=prefer

# --- Encryption (REQUIRED) ---
# Primary + fallback keys for key rotation. First key encrypts new data,
# all keys tried for decryption. Separate multiple keys with commas.
# FATAL: application will not start without this
ENCRYPTION_KEYS=
# Single-key fallback (use EITHER ENCRYPTION_KEYS or ENCRYPTION_KEY)
# ENCRYPTION_KEY=

# --- JWT Signing (REQUIRED) ---
# Generate: openssl rand -hex 32
# FATAL: application will not start without this
JWT_SECRET=

# --- Camo Proxy (REQUIRED) ---
# Generate: openssl rand -hex 32
CAMO_HMAC_KEY=

# --- Administration (REQUIRED for Mono Pro) ---
# Only this email can log in before a license is activated
ADMIN_EMAIL=

# --- Server ---
PORT=8080
UI_PORT=3000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# --- AI (optional) ---
# AI_DISABLE=false
# DEFAULT_AI_PROVIDER=openrouter
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.5-flash-preview
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Telegram (optional) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_NAME=

# --- Monitoring (optional) ---
# SENTRY_DSN=https://o000000.ingest.sentry.io/000000
# SENTRY_ENVIRONMENT=production

# --- Frontend (passed to Next.js at build time) ---
# NEXT_PUBLIC_SENTRY_DSN=${SENTRY_DSN}
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=${SENTRY_ENVIRONMENT:-production}
# NEXT_PUBLIC_EDITION=mono_pro

# --- Advanced ---
# PG_MAX_CONNS=20
# SYNC_BATCH_DELAY_MS=2000
# LOG_LEVEL=info

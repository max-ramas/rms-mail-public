# =============================================================================
# RMS Mail — Unified Edition
# =============================================================================
# Copy to .env and set your values.
# Generate encryption key: openssl rand -hex 32
# =============================================================================

# --- Database (REQUIRED) ---
# FATAL: application will not start without this (Unified only)
POSTGRES_USER=rmsmail
# FATAL: compose will refuse to start if empty
POSTGRES_PASSWORD=
POSTGRES_DB=rms-mail
REDIS_PASSWORD=rmsredis

# --- Encryption (REQUIRED) ---
# Primary + fallback keys for key rotation. First key encrypts new data,
# all keys tried for decryption. Separate multiple keys with commas.
# FATAL: application will not start without this
ENCRYPTION_KEYS=
# Single-key fallback (use EITHER ENCRYPTION_KEYS or ENCRYPTION_KEY)
# ENCRYPTION_KEY=

# --- JWT Signing (REQUIRED) ---
# Key for signing JWT auth tokens. Must be a random string (min 32 chars).
# Generate: openssl rand -hex 32
# FATAL: application will not start without this
JWT_SECRET=

# --- Camo Proxy (image privacy, REQUIRED) ---
# HMAC key for signing proxied image URLs. Must be set or app fails at startup.
# Generate: openssl rand -hex 32
CAMO_HMAC_KEY=

# --- Server ---
PORT=8080
UI_PORT=3000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
PUBLIC_URL=http://localhost:3000

# --- AI: Enterprise Lockdown ---
# Set to "true" to force all AI ops to use LLM_PROVIDER/LLM_MODEL,
# ignoring user-configured values in the web UI.
# LLM_ENVONLY=false
# LLM_PROVIDER=openrouter
# LLM_MODEL=

# --- AI: Provider API Keys (optional, can be set in web UI instead) ---
# OpenRouter (default, 200+ models)
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=
# OpenAI
# OPENAI_API_KEY=
# OPENAI_MODEL=
# Anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=
# Google Gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=
# DeepSeek
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=
# Groq
# GROQ_API_KEY=
# GROQ_MODEL=
# xAI (Grok)
# XAI_API_KEY=
# XAI_MODEL=
# Ollama (self-hosted)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=
# Qwen
# QWEN_API_KEY=
# QWEN_MODEL=
# OpenCode (self-hosted)
# OPENCODE_URL=
# OPENCODE_MODEL=
# Default provider if none configured in UI
# DEFAULT_AI_PROVIDER=openrouter

# --- Telegram Bot ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_NAME=
# Lock Telegram settings to env-only (ignores UI-configured token)
# TG_ENVONLY=false


# --- Mail Server Auto-Discovery ---
# Optional: trusted domains for auto-resolving IMAP/SMTP via hosting panel APIs.
# TRUSTED_MX_DOMAINS=

# --- Debug ---
# DEBUG=false

# AI features toggle (true = all AI disabled, no chat/summarize/autodraft)
AI_DISABLE=false
# ALLOW_GLOBAL_AI_KEYS=true  # Allow fallback to global AI provider keys (default: false)

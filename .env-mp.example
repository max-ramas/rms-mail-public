# =============================================================================
# RMS Mail — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the required values:
#   cp .env-mp.example .env
#
# Editions: Mono (M) — single user, Unified (U), Teams (T), Mono Pro (MP)
# =============================================================================

# --- Edition -----------------------------------------------------------------
# mono_pro | unified | teams (default: unified)
# Set via run-script or manually
# EDITION=mono_pro

# --- Administration ----------------------------------------------------------
# Automatically creates an administrator on first launch (Mono Pro / Teams only)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=strongpassword123

# --- Database ----------------------------------------------------------------
# PostgreSQL (required for Unified/Teams/Mono Pro, ignored in Mono)
# FATAL: application will not start without this
DATABASE_URL=postgres://user:${PG_PASSWORD:-change_me}@127.0.0.1:5437/geomail_mp?sslmode=require

# PostgreSQL port on host machine (for docker-compose)
PG_PORT=5437

# Redis port on host machine (for docker-compose, default 6387)
# REDIS_PORT=6387

# Redis URL (Unified/Teams/Mono Pro — for rate limiting, pub/sub, sessions)
# REDIS_URL=127.0.0.1:6387

# --- Security ----------------------------------------------------------------
# Data encryption key (256-bit, base64). Required for all editions.
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=

# Key for signing JWT tokens. Required for all editions.
# Must be unique and random (minimum 32 characters).
# If not set — ENCRYPTION_KEY is used (not recommended for production).
# Generate: openssl rand -base64 32
JWT_SECRET=

# HMAC key for proxying external images via Camo (required for all editions).
# If not set — the application will crash on startup.
# Generate: openssl rand -hex 32
CAMO_HMAC_KEY=

# --- Network & CORS ----------------------------------------------------------
# Allowed Origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3500

# Frontend URL (for OAuth redirects and links in emails)
FRONTEND_URL=http://localhost:3500

# Backend public URL (for Telegram webhook, OAuth callback)
# PUBLIC_URL=https://api.yourdomain.com

# Backend port (default: 8087)
# PORT=8087

# --- AI Providers ------------------------------------------------------------
# It is enough to configure at least one. Key + model for each provider.
# Default provider for TG chatbot (if not set — openai)
# DEFAULT_AI_PROVIDER=openrouter

# OpenRouter (multi-model proxy, recommended)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash-preview

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Groq (fast inference)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# xAI (Grok)
XAI_API_KEY=
XAI_MODEL=grok-3-mini

# Qwen (Alibaba)
QWEN_API_KEY=
QWEN_MODEL=qwen-plus

# Ollama (local model)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# OpenCode compatible API (any OpenAI-compatible endpoint)
# OPENCODE_URL=http://localhost:8080/v1
# OPENCODE_MODEL=local-model

# --- Telegram Bot ------------------------------------------------------------
# Bot token from @BotFather (global, for all users).
# If set — users CANNOT change the token via UI.
# If empty — user can input token via settings (Mono/Unified).
TELEGRAM_BOT_TOKEN=

# Bot name (username without @, fallback if /getMe is unavailable).
# Displayed in UI as a link t.me/<name> for quick access to the bot.
TELEGRAM_BOT_NAME=

# --- Mono: auto-setup mail account -------------------------------------------
# Only for EDITION=mono. If M_EMAIL is set and no accounts exist yet,
# an account is automatically created in DB on startup (no need to configure via UI).
#
# Required:
# M_EMAIL=your@gmail.com
# M_PASSWORD=your_app_password
#
# Optional (smart defaults from email domain):
# M_IMAP_HOST=imap.gmail.com    # default: imap.{domain}
# M_IMAP_PORT=993                # default: 993 (SSL/TLS)
# M_SMTP_HOST=smtp.gmail.com    # default: smtp.{domain}
# M_SMTP_PORT=587                # default: 587 (STARTTLS)

# --- MCP (Machine-Callable Protocol) -----------------------------------------
# Backend URL for MCP integrations (if different from the main one)
# MCP_API_URL=http://localhost:8087

# AI features toggle (true = all AI disabled, no chat/summarize/autodraft)
AI_DISABLE=false
# ALLOW_GLOBAL_AI_KEYS=true  # Allow fallback to global AI provider keys (default: false)

# Sentry / GlitchTip error monitoring (optional — leave empty to disable)
# SENTRY_DSN=https://publickey@your-sentry.example.com/project-id
# SENTRY_ENVIRONMENT=production
